local StealBox = MainTab:AddGroupbox({ Name = "Steal", Side = 2 })
StealBox:AddToggle("Steal", { Text = "Auto Steal", Default = false, Risky = false, Callback = function(value) 
    stealEnabled = value
    if not value then 
        unfreezeCharacter()
        goHome() 
    end
end })
StealBox:AddDropdown("IgnoreList", { Text = "Ignore List", Values = fruitNames, Multi = true, Callback = function(selected) ignoredSeeds = selected end })

