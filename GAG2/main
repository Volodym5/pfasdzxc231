local UI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Volodym5/pfasdzxc231/main/lib/source.lua"))()

local Window = UI:CreateWindow({
    Title          = "Garden Cheats",
    Size           = UDim2.fromOffset(500, 400),
    Center         = true,
    Resizable      = true,
    ToggleKeybind  = Enum.KeyCode.RightControl,
    AutoShow       = true,
})

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Networking = require(game.ReplicatedStorage.SharedModules.Networking)

-- Make all prompts instant
for _, prompt in ipairs(game:GetDescendants()) do
    if prompt:IsA("ProximityPrompt") then
        prompt.HoldDuration = 0
    end
end
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") then
        obj.HoldDuration = 0
    end
end)

local harvestEnabled = false
local stealEnabled = false
local sellEnabled = false
local seedPackEnabled = false
local lastHarvest = 0
local lastSell = 0
local harvestDelay = 0.1
local sellDelay = 2
local lastSteal = 0
local stealDelay = 0.15
local stealIndex = 0
local stealTargets = {}
local lastSeedPack = 0
local seedPackDelay = 1
local homePosition = nil

-- WalkSpeed (looped)
local walkSpeedEnabled = false
local walkSpeedValue = 24
local walkSpeedConnection = nil

local function startWalkSpeed()
    if walkSpeedConnection then return end
    walkSpeedConnection = RunService.RenderStepped:Connect(function()
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = walkSpeedValue
            end
        end
    end)
end

local function stopWalkSpeed()
    if walkSpeedConnection then
        walkSpeedConnection:Disconnect()
        walkSpeedConnection = nil
    end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16
        end
    end
end

-- Normal Fly
local flyEnabled = false
local flySpeed = 50
local flyConnection = nil

local function startFly()
    if flyConnection then return end
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local humanoid = char.Humanoid
        
        local bodyGyro = Instance.new("BodyGyro")
        bodyGyro.P = 9e4
        bodyGyro.MaxTorque = Vector3.new(9e4, 9e4, 9e4)
        bodyGyro.CFrame = root.CFrame
        bodyGyro.Parent = root
        
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Velocity = Vector3.zero
        bodyVelocity.MaxForce = Vector3.new(9e4, 9e4, 9e4)
        bodyVelocity.Parent = root
        
        humanoid.PlatformStand = true
        
        flyConnection = RunService.RenderStepped:Connect(function()
            if not flyEnabled then return end
            if not root or not root.Parent then return end
            
            bodyGyro.CFrame = workspace.CurrentCamera.CFrame
            
            local moveVector = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + workspace.CurrentCamera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - workspace.CurrentCamera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - workspace.CurrentCamera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + workspace.CurrentCamera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveVector = moveVector - Vector3.new(0, 1, 0) end
            
            bodyVelocity.Velocity = moveVector.Magnitude > 0 and moveVector.Unit * flySpeed or Vector3.zero
        end)
    end
end

local function stopFly()
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    local char = player.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChild("Humanoid")
        if root then
            local bg = root:FindFirstChild("BodyGyro")
            if bg then bg:Destroy() end
            local bv = root:FindFirstChild("BodyVelocity")
            if bv then bv:Destroy() end
        end
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

-- Check if it's night
local function isNightTime()
    local night = game.ReplicatedStorage:FindFirstChild("Night")
    if night and night:IsA("BoolValue") then
        return night.Value == true
    end
    return false
end

-- Seed Pack Collector
local function collectSeedPack()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local seedPackPart = workspace.Map.SeedPackSpawnServerLocations:FindFirstChild("Part")
    if seedPackPart and seedPackPart:IsA("BasePart") then
        root.CFrame = seedPackPart.CFrame * CFrame.new(0, 2, 2)
        task.wait(0.1)
        local prompt = seedPackPart:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            fireproximityprompt(prompt)
        end
        firetouchinterest(root, seedPackPart, 0)
        firetouchinterest(root, seedPackPart, 1)
    end
end

local function isPlotUnlocked(plotNum)
    local plotGui = player.PlayerGui:FindFirstChild("Plot" .. plotNum)
    if plotGui then
        local playerFrame = plotGui:FindFirstChild("PlayerFrame")
        if playerFrame then
            local unlocked = playerFrame:FindFirstChild("Unlocked")
            if unlocked then
                return unlocked.Visible
            end
        end
    end
    return false
end

local function getStealTargets()
    local targets = {}
    local myUserId = player.UserId
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "HarvestPart" and obj:IsA("BasePart") and obj.Parent then
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if not prompt or prompt.ActionText ~= "Steal" then continue end
            
            local fruitModel = obj.Parent
            local plant = fruitModel.Parent
            if not plant then continue end
            
            local userId = plant:GetAttribute("UserId")
            local plantId = plant:GetAttribute("PlantId")
            local fruitId = fruitModel:GetAttribute("FruitId") or fruitModel.Name
            
            if not userId or userId == myUserId then continue end
            if not plantId then continue end
            
            local current = obj
            local plotNum = nil
            while current do
                if current.Name:find("^Plot%d+$") then
                    plotNum = tonumber(current.Name:match("%d+$"))
                    break
                end
                current = current.Parent
            end
            
            if plotNum and isPlotUnlocked(plotNum) then
                table.insert(targets, {
                    part = obj,
                    userId = userId,
                    plantId = plantId,
                    fruitId = fruitId or ""
                })
            end
        end
    end
    return targets
end

local function getHomePosition()
    local myUserId = player.UserId
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                if plant:GetAttribute("UserId") == myUserId then
                    local sp = plot:FindFirstChild("SpawnPoint")
                    if sp and sp:IsA("BasePart") then
                        return sp.Position + Vector3.new(0, 3, 0)
                    end
                end
                break
            end
        end
    end
    return nil
end

local function goHome()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if not homePosition then
        homePosition = getHomePosition()
    end
    if homePosition then
        root.CFrame = CFrame.new(homePosition)
    end
end

local function doHarvest()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "HarvestPart" and obj:IsA("BasePart") and obj.Parent then
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if prompt and prompt.ActionText == "Harvest" then
                fireproximityprompt(prompt)
                firetouchinterest(root, obj, 0)
                firetouchinterest(root, obj, 1)
            end
        end
    end
end

local function doSteal()
    if not isNightTime() then return end
    
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    if #stealTargets == 0 then
        stealTargets = getStealTargets()
        stealIndex = 0
        if #stealTargets == 0 then return end
    end
    
    stealIndex = stealIndex + 1
    if stealIndex > #stealTargets then
        stealIndex = 1
        stealTargets = getStealTargets()
    end
    
    if #stealTargets == 0 then return end
    
    local target = stealTargets[stealIndex]
    if not target or not target.part or not target.part.Parent then
        stealTargets = getStealTargets()
        return
    end
    
    -- Use BeginSteal + CompleteSteal packets like the game does
    Networking.Steal.BeginSteal:Fire(target.userId, target.plantId, target.fruitId)
    Networking.Steal.CompleteSteal:Fire()
end

local function doSell()
    pcall(function()
        Networking.NPCS.SellAll:Fire()
    end)
end

RunService.Heartbeat:Connect(function()
    local now = tick()
    if harvestEnabled and now - lastHarvest > harvestDelay then
        lastHarvest = now
        doHarvest()
    end
    if sellEnabled and now - lastSell > sellDelay then
        lastSell = now
        doSell()
    end
    if stealEnabled and now - lastSteal > stealDelay then
        lastSteal = now
        doSteal()
    end
    if seedPackEnabled and now - lastSeedPack > seedPackDelay then
        lastSeedPack = now
        collectSeedPack()
    end
end)

-- Farming Tab
local FarmTab = Window:AddTab("Farming")
local FarmBox = FarmTab:AddGroupbox({ Name = "Auto Farm", Side = 1 })

FarmBox:AddToggle("Harvest", {
    Text = "Auto Harvest",
    Default = false,
    Callback = function(value)
        harvestEnabled = value
    end,
})

FarmBox:AddToggle("Steal", {
    Text = "Auto Steal",
    Default = false,
    Risky = true,
    Callback = function(value)
        stealEnabled = value
        if not value then goHome() else stealTargets = {} end
    end,
})

FarmBox:AddToggle("Sell", {
    Text = "Auto Sell",
    Default = false,
    Callback = function(value)
        sellEnabled = value
    end,
})

FarmBox:AddToggle("SeedPack", {
    Text = "Auto Seed Pack",
    Default = false,
    Callback = function(value)
        seedPackEnabled = value
    end,
})

-- Player Tab
local PlayerTab = Window:AddTab("Player")
local MovementBox = PlayerTab:AddGroupbox({ Name = "Movement", Side = 1 })

MovementBox:AddToggle("WalkSpeed", {
    Text = "WalkSpeed",
    Default = false,
    Callback = function(value)
        walkSpeedEnabled = value
        if value then startWalkSpeed() else stopWalkSpeed() end
    end,
})

MovementBox:AddSlider("WalkSpeedValue", {
    Text = "Walk Speed",
    Default = 24,
    Min = 16,
    Max = 200,
    Rounding = 0,
    Callback = function(value)
        walkSpeedValue = value
    end,
})

MovementBox:AddKeyPicker("WalkSpeedKey", {
    Text = "WalkSpeed",
    Default = "V",
    Mode = "Toggle",
    Callback = function()
        walkSpeedEnabled = not walkSpeedEnabled
        UI.Toggles.WalkSpeed:SetValue(walkSpeedEnabled)
        if walkSpeedEnabled then startWalkSpeed() else stopWalkSpeed() end
    end,
})

MovementBox:AddToggle("Fly", {
    Text = "Fly",
    Default = false,
    Callback = function(value)
        flyEnabled = value
        if value then startFly() else stopFly() end
    end,
})

MovementBox:AddSlider("FlySpeed", {
    Text = "Fly Speed",
    Default = 50,
    Min = 10,
    Max = 200,
    Rounding = 0,
    Callback = function(value)
        flySpeed = value
    end,
})

MovementBox:AddKeyPicker("FlyKey", {
    Text = "Fly",
    Default = "B",
    Mode = "Toggle",
    Callback = function()
        flyEnabled = not flyEnabled
        UI.Toggles.Fly:SetValue(flyEnabled)
        if flyEnabled then startFly() else stopFly() end
    end,
})

MovementBox:AddKeyPicker("HomeKey", {
    Text = "Teleport Home",
    Default = "T",
    Mode = "Always",
    Callback = function()
        goHome()
    end,
})
