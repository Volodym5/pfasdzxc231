local UI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Volodym5/pfasdzxc231/main/lib/source.lua"))()

local Window = UI:CreateWindow({
    Title          = "GAG2",
    Size           = UDim2.fromOffset(500, 450),
    Center         = true,
    Resizable      = true,
    ToggleKeybind  = Enum.KeyCode.RightShift,
    AutoShow       = true,
    ConfigFolder    = "GAG2",
})

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Networking = require(game.ReplicatedStorage.SharedModules.Networking)
local CollectionService = game:GetService("CollectionService")

local fruitNames = {
    "Carrot", "Strawberry", "Blueberry", "Tulip", "Tomato", "Apple",
    "Bamboo", "Corn", "Cactus", "Pineapple", "Mushroom", "Green Bean",
    "Banana", "Grape", "Coconut", "Mango", "Dragon Fruit", "Acorn",
    "Cherry", "Sunflower", "Venus Fly Trap", "Pomegranate", "Poison Apple",
    "Moon Bloom", "Dragon's Breath",
}

local gearNames = {
    "Common Watering Can", "Common Sprinkler", "Sign", "Lantern",
    "Wheelbarrow", "Uncommon Sprinkler", "Rare Sprinkler",
    "Legendary Sprinkler", "Super Sprinkler", "Trowel",
    "Speed Mushroom", "Jump Mushroom", "Gnome", "Shrink Mushroom",
    "Supersize Mushroom", "Invisibility Mushroom", "Teleporter",
    "Super Watering Can", "Basic Pot", "Flashbang",
}

for _, prompt in ipairs(game:GetDescendants()) do
    if prompt:IsA("ProximityPrompt") and prompt.ActionText == "Harvest" then
        prompt.HoldDuration = 0
    end
end
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") and obj.ActionText == "Harvest" then
        obj.HoldDuration = 0
    end
end)

local harvestEnabled = false
local stealEnabled = false
local sellEnabled = false
local seedPackEnabled = false
local autoBuySeedsEnabled = false
local autoBuyGearsEnabled = false
local autoBuySeeds = {}
local autoBuyGears = {}
local buySeedIndex = 0
local buyGearIndex = 0
local lastSell = 0
local sellDelay = 2
local lastSeedPack = 0
local seedPackDelay = 0.005
local lastAutoBuySeed = 0
local lastAutoBuyGear = 0
local autoBuyDelay = 0.07
local ignoredSeeds = {}

-- Harvest - scan every 4s, collect every 0.1s
local harvestCache = {}
local lastHarvestScan = 0
local harvestScanDelay = 4
local harvestIndex = 0
local harvestCollectDelay = 0.1
local lastHarvestCollect = 0

local antiCactusEnabled = false
local noErrorSoundEnabled = false
local antiGhostPepperEnabled = false
local antiDragonEnabled = false
local ghostPepperParts = {}
local dragonParts = {}

local walkSpeedEnabled = false
local walkSpeedValue = 40
local walkSpeedConnection = nil
local jumpPowerEnabled = false
local jumpPowerValue = 50
local defaultJumpPower = 50

local function startWalkSpeed()
    if walkSpeedConnection then return end
    walkSpeedConnection = RunService.RenderStepped:Connect(function()
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then humanoid.WalkSpeed = walkSpeedValue end
        end
    end)
end

local function stopWalkSpeed()
    if walkSpeedConnection then walkSpeedConnection:Disconnect(); walkSpeedConnection = nil end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then humanoid.WalkSpeed = 16 end
    end
end

local function updateJumpPower()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.UseJumpPower = true
            humanoid.JumpPower = jumpPowerEnabled and jumpPowerValue or defaultJumpPower
        end
    end
end

player.CharacterAdded:Connect(function()
    task.wait(0.1)
    updateJumpPower()
end)

local flyEnabled = false
local flySpeed = 100
local flyConnection = nil

local function startFly()
    if flyConnection then return end
    local char = player.Character
    if char and char:FindFirstChild("Head") then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local head = char.Head
        humanoid.PlatformStand = true
        head.Anchored = true
        flyConnection = RunService.Heartbeat:Connect(function(deltaTime)
            if not flyEnabled then return end
            if not char or not char.Parent then return end
            local moveDirection = humanoid.MoveDirection * (flySpeed * deltaTime)
            local headCFrame = head.CFrame
            local camera = workspace.CurrentCamera
            local cameraCFrame = camera.CFrame
            local cameraOffset = headCFrame:ToObjectSpace(cameraCFrame).Position
            cameraCFrame = cameraCFrame * CFrame.new(-cameraOffset.X, -cameraOffset.Y, -cameraOffset.Z + 1)
            local cameraPosition = cameraCFrame.Position
            local headPosition = headCFrame.Position
            local objectSpaceVelocity = CFrame.new(cameraPosition, Vector3.new(headPosition.X, cameraPosition.Y, headPosition.Z)):VectorToObjectSpace(moveDirection)
            head.CFrame = CFrame.new(headPosition) * (cameraCFrame - cameraPosition) * CFrame.new(objectSpaceVelocity)
        end)
    end
end

local function stopFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        if humanoid then humanoid.PlatformStand = false end
        if head then head.Anchored = false end
    end
end

local function freezeCharacter()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if humanoid then humanoid.PlatformStand = true end
        if root then root.Anchored = true end
    end
end

local function unfreezeCharacter()
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then root.Anchored = false end
        if humanoid then humanoid.PlatformStand = false end
    end
end

local function isPlotUnlocked(plotNum)
    local plotGui = player.PlayerGui:FindFirstChild("Plot" .. plotNum)
    if plotGui then
        local playerFrame = plotGui:FindFirstChild("PlayerFrame")
        if playerFrame then
            local unlocked = playerFrame:FindFirstChild("Unlocked")
            if unlocked then return unlocked.Visible end
        end
    end
    return false
end

local function getMyPlotMidpoint()
    local myUserId = player.UserId
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        if plot.Name:find("^Plot%d+$") then
            local ownerId = plot:GetAttribute("OwnerUserId")
            if ownerId == myUserId then
                local visual = plot:FindFirstChild("Visual")
                if visual then
                    local col1 = visual:FindFirstChild("PlantAreaColumn1")
                    local col2 = visual:FindFirstChild("PlantAreaColumn2")
                    if col1 and col2 and col1:IsA("BasePart") and col2:IsA("BasePart") then
                        return (col1.Position + col2.Position) / 2
                    end
                end
            end
        end
    end
    return nil
end

local function goHome()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local homePos = getMyPlotMidpoint()
    if homePos then
        root.CFrame = CFrame.new(homePos + Vector3.new(0, 3, 0))
        root.AssemblyLinearVelocity = Vector3.zero
    end
end

local function collectSeedPack()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local part = workspace.Map.SeedPackSpawnServerLocations:FindFirstChild("Part")
    if part and part:IsA("BasePart") then
        root.CFrame = part.CFrame * CFrame.new(0, 2, 2)
        task.wait(0.1)
        local prompt = part:FindFirstChildOfClass("ProximityPrompt")
        if prompt then fireproximityprompt(prompt) end
        firetouchinterest(root, part, 0)
        firetouchinterest(root, part, 1)
    end
end

-- Scan for harvestable fruits
local function scanHarvest()
    table.clear(harvestCache)
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        local owner = plot:GetAttribute("Owner")
        if owner == player.Name then
            for _, obj in ipairs(plot:GetDescendants()) do
                if obj.Name == "HarvestPart" and obj:IsA("BasePart") then
                    local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and prompt.ActionText == "Harvest" then
                        table.insert(harvestCache, {part = obj, prompt = prompt})
                    end
                end
            end
            break
        end
    end
    harvestIndex = 0
end

-- Collect one fruit from cache
local function doHarvest()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    if #harvestCache == 0 then return end
    
    harvestIndex = harvestIndex + 1
    if harvestIndex > #harvestCache then
        harvestIndex = 1
    end
    
    local target = harvestCache[harvestIndex]
    if not target or not target.part or not target.part.Parent then
        table.remove(harvestCache, harvestIndex)
        harvestIndex = harvestIndex - 1
        return
    end
    
    fireproximityprompt(target.prompt)
    firetouchinterest(root, target.part, 0)
    firetouchinterest(root, target.part, 1)
end

-- Check if plot has fruits worth stealing
local function plotHasStealableFruits(plot)
    local plants = plot:FindFirstChild("Plants")
    if not plants then return false end
    
    for _, plant in ipairs(plants:GetChildren()) do
        local userId = plant:GetAttribute("UserId")
        if userId and userId ~= player.UserId then
            local seedName = plant:GetAttribute("SeedName")
            if not seedName or not ignoredSeeds[seedName] then
                local fruits = plant:FindFirstChild("Fruits")
                if fruits and #fruits:GetChildren() > 0 then
                    return true
                end
                if plant:FindFirstChild("HarvestPart") then
                    return true
                end
            end
        end
    end
    return false
end

-- Steal
local function getUnlockedPlots()
    local myUserId = player.UserId
    local plots = {}
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        if plot.Name:find("^Plot%d+$") then
            local plotNum = tonumber(plot.Name:match("%d+$"))
            local ownerId = plot:GetAttribute("OwnerUserId")
            if ownerId and ownerId ~= myUserId and isPlotUnlocked(plotNum) then
                if plotHasStealableFruits(plot) then
                    local visual = plot:FindFirstChild("Visual")
                    if visual then
                        local col1 = visual:FindFirstChild("PlantAreaColumn1")
                        local col2 = visual:FindFirstChild("PlantAreaColumn2")
                        if col1 and col2 and col1:IsA("BasePart") and col2:IsA("BasePart") then
                            local midPoint = (col1.Position + col2.Position) / 2
                            table.insert(plots, {plotNum = plotNum, position = midPoint + Vector3.new(0, -7, 0)})
                        end
                    end
                end
            end
        end
    end
    return plots
end

local function collectFruitsOnPlot(plot)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local plants = plot:FindFirstChild("Plants")
    if not plants then return end
    
    for _, plant in ipairs(plants:GetChildren()) do
        local userId = plant:GetAttribute("UserId")
        if userId and userId ~= player.UserId then
            local seedName = plant:GetAttribute("SeedName")
            if not seedName or not ignoredSeeds[seedName] then
                local fruits = plant:FindFirstChild("Fruits")
                if fruits then
                    for _, fruit in ipairs(fruits:GetChildren()) do
                        local hp = fruit:FindFirstChild("HarvestPart")
                        if hp then
                            local prompt = hp:FindFirstChildOfClass("ProximityPrompt")
                            if prompt and prompt.ActionText == "Steal" then
                                fireproximityprompt(prompt)
                                firetouchinterest(root, hp, 0)
                                firetouchinterest(root, hp, 1)
                                if prompt.HoldDuration > 0 then
                                    fireproximityprompt(prompt)
                                end
                            end
                        end
                    end
                end
                local hp = plant:FindFirstChild("HarvestPart")
                if hp then
                    local prompt = hp:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and prompt.ActionText == "Steal" then
                        fireproximityprompt(prompt)
                        firetouchinterest(root, hp, 0)
                        firetouchinterest(root, hp, 1)
                        if prompt.HoldDuration > 0 then
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end
        end
    end
end

local function doStealCycle()
    local plots = getUnlockedPlots()
    if #plots == 0 then return end
    for i = #plots, 2, -1 do
        local j = math.random(1, i)
        plots[i], plots[j] = plots[j], plots[i]
    end
    
    -- Freeze for entire steal session
    freezeCharacter()
    
    for _, plotData in ipairs(plots) do
        if not stealEnabled then break end
        
        local plot = workspace.Gardens:FindFirstChild("Plot" .. plotData.plotNum)
        if plot and plotHasStealableFruits(plot) then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then break end
            
            -- Direct teleport since we're frozen
            root.CFrame = CFrame.new(plotData.position)
            root.AssemblyLinearVelocity = Vector3.zero
            
            -- Collect for 2 seconds
            local endTime = tick() + 2
            while tick() < endTime and stealEnabled do
                collectFruitsOnPlot(plot)
                task.wait(0.05)
            end
        end
    end
    
    if stealEnabled then
        local homePos = getMyPlotMidpoint()
        if homePos then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(homePos + Vector3.new(0, 3, 0))
                root.AssemblyLinearVelocity = Vector3.zero
            end
        end
    end
end

local function doSell()
    pcall(function() Networking.NPCS.SellAll:Fire() end)
end

local function doAutoBuySeeds()
    local buyList = {}
    for seed, enabled in pairs(autoBuySeeds) do
        if enabled then table.insert(buyList, seed) end
    end
    if #buyList == 0 then return end
    buySeedIndex = buySeedIndex + 1
    if buySeedIndex > #buyList then buySeedIndex = 1 end
    pcall(function() Networking.SeedShop.PurchaseSeed:Fire(buyList[buySeedIndex]) end)
end

local function doAutoBuyGears()
    local buyList = {}
    for gear, enabled in pairs(autoBuyGears) do
        if enabled then table.insert(buyList, gear) end
    end
    if #buyList == 0 then return end
    buyGearIndex = buyGearIndex + 1
    if buyGearIndex > #buyList then buyGearIndex = 1 end
    pcall(function() Networking.GearShop.PurchaseGear:Fire(buyList[buyGearIndex]) end)
end

-- Block error sound
game.DescendantAdded:Connect(function(obj)
    if noErrorSoundEnabled and obj:IsA("Sound") then
        if obj.SoundId == "rbxassetid://550209561" then
            obj:Destroy()
        end
    end
end)

-- Anti Ghost Pepper (cached)
local function scanGhostPeppers()
    for _, obj in ipairs(CollectionService:GetTagged("GhostPepper")) do
        ghostPepperParts[obj] = true
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("BasePart") and CollectionService:HasTag(obj, "GhostPepper") then
        ghostPepperParts[obj] = true
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    ghostPepperParts[obj] = nil
end)

scanGhostPeppers()

local function processGhostPeppers()
    for part in pairs(ghostPepperParts) do
        if part.Parent then
            pcall(function() part:RemoveTag("GhostPepper") end)
        else
            ghostPepperParts[part] = nil
        end
    end
end

-- Anti Dragon (cached)
local function scanDragons()
    for _, obj in ipairs(CollectionService:GetTagged("DragonBreath")) do
        dragonParts[obj] = true
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Model") and CollectionService:HasTag(obj, "DragonBreath") then
        dragonParts[obj] = true
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    dragonParts[obj] = nil
end)

scanDragons()

local function processDragons()
    for model in pairs(dragonParts) do
        if model.Parent then
            pcall(function()
                local breathEnd = model:FindFirstChild("DragonBreathEnd", true)
                if breathEnd then
                    breathEnd:SetAttribute("Enabled", false)
                    for _, child in ipairs(breathEnd:GetDescendants()) do
                        if child:IsA("ParticleEmitter") or child:IsA("SurfaceGui") then
                            child.Enabled = false
                        end
                    end
                end
                local head = model:FindFirstChild("Head", true)
                if head then
                    local emitter = head:FindFirstChild("Emitter")
                    if emitter then
                        for _, child in ipairs(emitter:GetChildren()) do
                            if child:IsA("Beam") or child:IsA("ParticleEmitter") then
                                child.Enabled = false
                            end
                        end
                    end
                end
            end)
        else
            dragonParts[model] = nil
        end
    end
end

RunService.Heartbeat:Connect(function()
    local now = tick()
    
    if harvestEnabled then
        if now - lastHarvestScan > harvestScanDelay then
            lastHarvestScan = now
            scanHarvest()
        end
        if now - lastHarvestCollect > harvestCollectDelay then
            lastHarvestCollect = now
            doHarvest()
        end
    end
    
    if sellEnabled and now - lastSell > sellDelay then
        lastSell = now; doSell()
    end
    if seedPackEnabled and now - lastSeedPack > seedPackDelay then
        lastSeedPack = now; collectSeedPack()
    end
    if autoBuySeedsEnabled and now - lastAutoBuySeed > autoBuyDelay then
        lastAutoBuySeed = now; doAutoBuySeeds()
    end
    if autoBuyGearsEnabled and now - lastAutoBuyGear > autoBuyDelay then
        lastAutoBuyGear = now; doAutoBuyGears()
    end
    if antiGhostPepperEnabled then
        processGhostPeppers()
    end
    if antiDragonEnabled then
        processDragons()
    end
    if antiCactusEnabled then
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                pcall(function()
                    local parts = workspace:GetPartBoundsInRadius(root.Position, 20)
                    if parts then
                        for _, part in ipairs(parts) do
                            pcall(function()
                                if part and part.Parent and part.CanTouch then
                                    local p = part.Parent
                                    while p do
                                        local pName = p.Name or ""
                                        if pName:find("^Plot%d") then break end
                                        local seed = p:GetAttribute("SeedName")
                                        if seed == "Cactus" or seed == "Baby Cactus" then
                                            part.CanTouch = false
                                            break
                                        end
                                        p = p.Parent
                                    end
                                end
                            end)
                        end
                    end
                end)
            end
        end
    end
end)

task.spawn(function()
    while true do
        if stealEnabled then doStealCycle() end
        task.wait(1)
    end
end)

