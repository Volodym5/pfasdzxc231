local UI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Volodym5/pfasdzxc231/main/lib/source.lua"))()

local Window = UI:CreateWindow({
    Title          = "GAG2",
    Size           = UDim2.fromOffset(500, 450),
    Center         = true,
    Resizable      = true,
    ToggleKeybind  = Enum.KeyCode.RightShift,
    AutoShow       = true,
})

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Networking = require(game.ReplicatedStorage.SharedModules.Networking)

local fruitNames = {
    "Carrot", "Strawberry", "Blueberry", "Tulip", "Tomato", "Apple",
    "Bamboo", "Corn", "Cactus", "Pineapple", "Mushroom", "Green Bean",
    "Banana", "Grape", "Coconut", "Mango", "Dragon Fruit", "Acorn",
    "Cherry", "Sunflower", "Venus Fly Trap", "Pomegranate", "Poison Apple",
    "Moon Bloom", "Dragon's Breath",
}

for _, prompt in ipairs(game:GetDescendants()) do
    if prompt:IsA("ProximityPrompt") and prompt.ActionText == "Harvest" then
        prompt.HoldDuration = 0
    end
end
game.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") and obj.ActionText == "Harvest" then
        obj.HoldDuration = 0
    end
end)

local harvestEnabled = false
local stealEnabled = false
local sellEnabled = false
local seedPackEnabled = false
local autoBuyEnabled = false
local autoBuySeeds = {}
local buyIndex = 0
local lastHarvest = 0
local lastSell = 0
local harvestDelay = 0.1
local sellDelay = 2
local lastSeedPack = 0
local seedPackDelay = 0.01
local lastAutoBuy = 0
local autoBuyDelay = 0.2
local ignoredSeeds = {}

local antiCactusEnabled = false

local walkSpeedEnabled = false
local walkSpeedValue = 40
local walkSpeedConnection = nil

local function startWalkSpeed()
    if walkSpeedConnection then return end
    walkSpeedConnection = RunService.RenderStepped:Connect(function()
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then humanoid.WalkSpeed = walkSpeedValue end
        end
    end)
end

local function stopWalkSpeed()
    if walkSpeedConnection then walkSpeedConnection:Disconnect(); walkSpeedConnection = nil end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then humanoid.WalkSpeed = 16 end
    end
end

local flyEnabled = false
local flySpeed = 100
local flyConnection = nil

local function startFly()
    if flyConnection then return end
    local char = player.Character
    if char and char:FindFirstChild("Head") then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local head = char.Head
        humanoid.PlatformStand = true
        head.Anchored = true
        flyConnection = RunService.Heartbeat:Connect(function(deltaTime)
            if not flyEnabled then return end
            if not char or not char.Parent then return end
            local moveDirection = humanoid.MoveDirection * (flySpeed * deltaTime)
            local headCFrame = head.CFrame
            local camera = workspace.CurrentCamera
            local cameraCFrame = camera.CFrame
            local cameraOffset = headCFrame:ToObjectSpace(cameraCFrame).Position
            cameraCFrame = cameraCFrame * CFrame.new(-cameraOffset.X, -cameraOffset.Y, -cameraOffset.Z + 1)
            local cameraPosition = cameraCFrame.Position
            local headPosition = headCFrame.Position
            local objectSpaceVelocity = CFrame.new(cameraPosition, Vector3.new(headPosition.X, cameraPosition.Y, headPosition.Z)):VectorToObjectSpace(moveDirection)
            head.CFrame = CFrame.new(headPosition) * (cameraCFrame - cameraPosition) * CFrame.new(objectSpaceVelocity)
        end)
    end
end

local function stopFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        if humanoid then humanoid.PlatformStand = false end
        if head then head.Anchored = false end
    end
end

local function isPlotUnlocked(plotNum)
    local plotGui = player.PlayerGui:FindFirstChild("Plot" .. plotNum)
    if plotGui then
        local playerFrame = plotGui:FindFirstChild("PlayerFrame")
        if playerFrame then
            local unlocked = playerFrame:FindFirstChild("Unlocked")
            if unlocked then return unlocked.Visible end
        end
    end
    return false
end

local function getMyPlotMidpoint()
    local myUserId = player.UserId
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        if plot.Name:find("^Plot%d+$") then
            local ownerId = plot:GetAttribute("OwnerUserId")
            if ownerId == myUserId then
                local visual = plot:FindFirstChild("Visual")
                if visual then
                    local col1 = visual:FindFirstChild("PlantAreaColumn1")
                    local col2 = visual:FindFirstChild("PlantAreaColumn2")
                    if col1 and col2 and col1:IsA("BasePart") and col2:IsA("BasePart") then
                        return (col1.Position + col2.Position) / 2
                    end
                end
            end
        end
    end
    return nil
end

local function goHome()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local homePos = getMyPlotMidpoint()
    if homePos then
        root.CFrame = CFrame.new(homePos + Vector3.new(0, 3, 0))
    end
end

local function collectSeedPack()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local part = workspace.Map.SeedPackSpawnServerLocations:FindFirstChild("Part")
    if part and part:IsA("BasePart") then
        root.CFrame = part.CFrame * CFrame.new(0, 2, 2)
        task.wait(0.1)
        local prompt = part:FindFirstChildOfClass("ProximityPrompt")
        if prompt then fireproximityprompt(prompt) end
        firetouchinterest(root, part, 0)
        firetouchinterest(root, part, 1)
    end
end

local function doHarvest()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "HarvestPart" and obj:IsA("BasePart") and obj.Parent then
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if prompt and prompt.ActionText == "Harvest" then
                fireproximityprompt(prompt)
                firetouchinterest(root, obj, 0)
                firetouchinterest(root, obj, 1)
            end
        end
    end
end

-- Steal system
local function getUnlockedPlots()
    local myUserId = player.UserId
    local plots = {}
    for _, plot in ipairs(workspace.Gardens:GetChildren()) do
        if plot.Name:find("^Plot%d+$") then
            local plotNum = tonumber(plot.Name:match("%d+$"))
            local ownerId = plot:GetAttribute("OwnerUserId")
            if ownerId and ownerId ~= myUserId and isPlotUnlocked(plotNum) then
                local visual = plot:FindFirstChild("Visual")
                if visual then
                    local col1 = visual:FindFirstChild("PlantAreaColumn1")
                    local col2 = visual:FindFirstChild("PlantAreaColumn2")
                    if col1 and col2 and col1:IsA("BasePart") and col2:IsA("BasePart") then
                        local midPoint = (col1.Position + col2.Position) / 2
                        table.insert(plots, {
                            plotNum = plotNum,
                            position = midPoint + Vector3.new(0, -7, 0)
                        })
                    end
                end
            end
        end
    end
    return plots
end

local function collectFruitsOnPlot(plotNum)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local myUserId = player.UserId
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "HarvestPart" and obj:IsA("BasePart") and obj.Parent then
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if prompt and prompt.ActionText == "Steal" then
                local fruitModel = obj.Parent
                local plantModel = fruitModel.Parent and fruitModel.Parent.Parent
                if plantModel then
                    local userId = plantModel:GetAttribute("UserId")
                    local seedName = plantModel:GetAttribute("SeedName")
                    if userId and userId ~= myUserId then
                        if not seedName or not ignoredSeeds[seedName] then
                            local current = obj
                            local fruitPlotNum = nil
                            while current do
                                if current.Name:find("^Plot%d+$") then
                                    fruitPlotNum = tonumber(current.Name:match("%d+$"))
                                    break
                                end
                                current = current.Parent
                            end
                            if fruitPlotNum == plotNum then
                                fireproximityprompt(prompt)
                                firetouchinterest(root, obj, 0)
                                firetouchinterest(root, obj, 1)
                                if prompt.HoldDuration > 0 then
                                    fireproximityprompt(prompt)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

local function doStealCycle()
    local plots = getUnlockedPlots()
    if #plots == 0 then return end
    
    -- Shuffle
    for i = #plots, 2, -1 do
        local j = math.random(1, i)
        plots[i], plots[j] = plots[j], plots[i]
    end
    
    for _, plot in ipairs(plots) do
        if not stealEnabled then break end
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(plot.position)
            end
        end
        
        local endTime = tick() + 2
        while tick() < endTime and stealEnabled do
            collectFruitsOnPlot(plot.plotNum)
            task.wait(0.1)
        end
    end
    
    if stealEnabled then
        goHome()
    end
end

local function doSell()
    pcall(function() Networking.NPCS.SellAll:Fire() end)
end

local function doAutoBuy()
    local buyList = {}
    for seed, enabled in pairs(autoBuySeeds) do
        if enabled then table.insert(buyList, seed) end
    end
    if #buyList == 0 then return end
    buyIndex = buyIndex + 1
    if buyIndex > #buyList then buyIndex = 1 end
    pcall(function() Networking.SeedShop.PurchaseSeed:Fire(buyList[buyIndex]) end)
end

RunService.Heartbeat:Connect(function()
    local now = tick()
    if harvestEnabled and now - lastHarvest > harvestDelay then
        lastHarvest = now; doHarvest()
    end
    if sellEnabled and now - lastSell > sellDelay then
        lastSell = now; doSell()
    end
    if seedPackEnabled and now - lastSeedPack > seedPackDelay then
        lastSeedPack = now; collectSeedPack()
    end
    if autoBuyEnabled and now - lastAutoBuy > autoBuyDelay then
        lastAutoBuy = now; doAutoBuy()
    end
    if antiCactusEnabled then
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                pcall(function()
                    local parts = workspace:GetPartBoundsInRadius(root.Position, 20)
                    if parts then
                        for _, part in ipairs(parts) do
                            pcall(function()
                                if part and part.Parent and part.CanTouch then
                                    local p = part.Parent
                                    while p do
                                        local pName = p.Name or ""
                                        if pName:find("^Plot%d") then break end
                                        local seed = p:GetAttribute("SeedName")
                                        if seed == "Cactus" or seed == "Baby Cactus" then
                                            part.CanTouch = false
                                            break
                                        end
                                        p = p.Parent
                                    end
                                end
                            end)
                        end
                    end
                end)
            end
        end
    end
end)

-- Steal runs in its own thread
task.spawn(function()
    while true do
        if stealEnabled then
            doStealCycle()
        end
        task.wait(1)
    end
end)

-- Main Tab
local MainTab = Window:AddTab("Main")

local FarmBox = MainTab:AddGroupbox({ Name = "Auto Farm", Side = 1 })
FarmBox:AddToggle("Harvest", {
    Text = "Auto Harvest", Default = false,
    Callback = function(value) harvestEnabled = value end,
})
FarmBox:AddToggle("Sell", {
    Text = "Auto Sell", Default = false,
    Callback = function(value) sellEnabled = value end,
})
FarmBox:AddToggle("SeedPack", {
    Text = "Auto Seed Pack", Default = false,
    Callback = function(value) seedPackEnabled = value end,
})

local StealBox = MainTab:AddGroupbox({ Name = "Steal", Side = 2 })
StealBox:AddToggle("Steal", {
    Text = "Auto Steal", Default = false, Risky = false,
    Callback = function(value)
        stealEnabled = value
        if not value then goHome() end
    end,
})
StealBox:AddDropdown("IgnoreList", {
    Text = "Ignore List", Values = fruitNames, Multi = true,
    Callback = function(selected) ignoredSeeds = selected end,
})

local BuyBox = MainTab:AddGroupbox({ Name = "Auto Buy", Side = 1 })
BuyBox:AddToggle("AutoBuy", {
    Text = "Auto Buy Seeds", Default = false,
    Callback = function(value) autoBuyEnabled = value end,
})
BuyBox:AddDropdown("BuySeed", {
    Text = "Seeds to Buy", Values = fruitNames, Multi = true,
    Callback = function(selected) autoBuySeeds = selected end,
})

local AntiBox = MainTab:AddGroupbox({ Name = "Anti", Side = 2 })
AntiBox:AddToggle("AntiCactus", {
    Text = "Anti Cactus", Default = false,
    Callback = function(value) antiCactusEnabled = value end,
})

-- Player Tab
local PlayerTab = Window:AddTab("Player")
local MovementBox = PlayerTab:AddGroupbox({ Name = "Movement", Side = 1 })

MovementBox:AddToggle("WalkSpeed", {
    Text = "WalkSpeed", Default = false,
    Callback = function(value)
        walkSpeedEnabled = value
        if value then startWalkSpeed() else stopWalkSpeed() end
    end,
})
MovementBox:AddSlider("WalkSpeedValue", {
    Text = "Walk Speed", Default = 24, Min = 16, Max = 200, Rounding = 0,
    Callback = function(value) walkSpeedValue = value end,
})
MovementBox:AddKeyPicker("WalkSpeedKey", {
    Text = "WalkSpeed", Default = "V", Mode = "Toggle",
    Callback = function()
        walkSpeedEnabled = not walkSpeedEnabled
        UI.Toggles.WalkSpeed:SetValue(walkSpeedEnabled)
        if walkSpeedEnabled then startWalkSpeed() else stopWalkSpeed() end
    end,
})
MovementBox:AddToggle("Fly", {
    Text = "Fly", Default = false,
    Callback = function(value)
        flyEnabled = value
        if value then startFly() else stopFly() end
    end,
})
MovementBox:AddSlider("FlySpeed", {
    Text = "Fly Speed", Default = 50, Min = 10, Max = 200, Rounding = 0,
    Callback = function(value) flySpeed = value end,
})
MovementBox:AddKeyPicker("FlyKey", {
    Text = "Fly", Default = "B", Mode = "Toggle",
    Callback = function()
        flyEnabled = not flyEnabled
        UI.Toggles.Fly:SetValue(flyEnabled)
        if flyEnabled then startFly() else stopFly() end
    end,
})
MovementBox:AddKeyPicker("HomeKey", {
    Text = "Teleport Home", Default = "T", Mode = "Always",
    Callback = function() goHome() end,
})
