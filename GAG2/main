-- Player Tab
local PlayerTab = Window:AddTab("Player")
local MovementBox = PlayerTab:AddGroupbox({ Name = "Movement", Side = 1 })

MovementBox:AddToggle("WalkSpeed", { Text = "WalkSpeed", Default = false, Callback = function(value) walkSpeedEnabled = value; if value then startWalkSpeed() else stopWalkSpeed() end end })
MovementBox:AddSlider("WalkSpeedValue", { Text = "Walk Speed", Default = 24, Min = 16, Max = 200, Rounding = 0, Callback = function(value) walkSpeedValue = value end })
MovementBox:AddKeyPicker("WalkSpeedKey", { Text = "WalkSpeed", Default = "V", Mode = "Toggle", Callback = function() walkSpeedEnabled = not walkSpeedEnabled; UI.Toggles.WalkSpeed:SetValue(walkSpeedEnabled); if walkSpeedEnabled then startWalkSpeed() else stopWalkSpeed() end end })
MovementBox:AddToggle("JumpPower", { Text = "Jump Power", Default = false, Callback = function(value) jumpPowerEnabled = value; updateJumpPower() end })
MovementBox:AddSlider("JumpPowerValue", { Text = "Jump Height", Default = 50, Min = 50, Max = 500, Rounding = 0, Callback = function(value) jumpPowerValue = value; updateJumpPower() end })
MovementBox:AddToggle("Fly", { Text = "Fly", Default = false, Callback = function(value) flyEnabled = value; if value then startFly() else stopFly() end end })
MovementBox:AddSlider("FlySpeed", { Text = "Fly Speed", Default = 50, Min = 10, Max = 200, Rounding = 0, Callback = function(value) flySpeed = value end })
MovementBox:AddKeyPicker("FlyKey", { Text = "Fly", Default = "B", Mode = "Toggle", Callback = function() flyEnabled = not flyEnabled; UI.Toggles.Fly:SetValue(flyEnabled); if flyEnabled then startFly() else stopFly() end end })
MovementBox:AddKeyPicker("HomeKey", { Text = "Teleport Home", Default = "T", Mode = "Always", Callback = function() goHome() end })
